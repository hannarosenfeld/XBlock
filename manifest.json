{
  "manifest_version": 3,
  "name": "X Styler",
  "version": "1.2",
  "permissions": ["scripting", "declarativeNetRequest"],
  "host_permissions": ["https://x.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["index.js"],
      "run_at": "document_idle"
    }
  ]
}